# ── Telegram bot (сповіщення майстру про новий запис) ──
# 1) Створи бота через @BotFather → отримай TOKEN
# 2) Дізнайся свій chat_id: напиши боту, відкрий
#    https://api.telegram.org/bot<TOKEN>/getUpdates → поле chat.id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Адмінка: JWT-автентифікація ──
# JWT_SECRET — секрет для підпису токенів (у проді став довгий випадковий рядок).
JWT_SECRET=dev-insecure-secret-change-me
JWT_EXPIRE_MINUTES=720
# Початковий супер-адмін (створюється при першому старті, якщо ще немає).
# Зміна пароля пізніше НЕ оновить існуючого користувача — задай до першого seed.
SUPER_ADMIN_EMAIL=admin@ostrie.local
SUPER_ADMIN_PASSWORD=ostrie-admin

# ADMIN_TOKEN — легасі, ендпоінтами більше не використовується
ADMIN_TOKEN=change-me

# ── База даних ──
# SQLite за замовчуванням. Для Postgres достатньо вказати будь-який із форматів —
# додаток сам нормалізує схему під драйвер psycopg3:
#   postgres://...  /  postgresql://...  /  postgresql+psycopg://...
# На Render DATABASE_URL підставляється автоматично з блоку databases у render.yaml.
DATABASE_URL=sqlite:///./ostrie.db

# ── CORS (домени фронтенду, через кому) ──
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
